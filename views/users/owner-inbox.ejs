<% layout("/layouts/boilerplate") %>

<style>
    .owner-inbox-page {
        background: linear-gradient(135deg, #fff7ed 0%, #fef2f2 100%);
        padding: 3rem 0;
    }

    .owner-inbox-wrapper {
        background: white;
        border-radius: 22px;
        padding: 2rem;
        box-shadow: 0 22px 45px rgba(0,0,0,0.08);
    }

    .owner-inbox-title {
        font-size: 2.1rem;
        font-weight: 700;
        color: #222;
        margin-bottom: 1.5rem;
    }

    .message-card {
        border: none;
        border-radius: 18px;
        background: #fffaf5;
        box-shadow: 0 14px 30px rgba(0,0,0,0.06);
        height: 100%;
    }

    .message-card-body {
        padding: 1.6rem;
    }

    .message-subject {
        font-size: 1.2rem;
        font-weight: 700;
        color: #222;
        margin-bottom: 0.6rem;
    }

    .message-meta {
        color: #6b7280;
        line-height: 1.8;
        font-size: 0.98rem;
        margin-bottom: 1rem;
    }

    .message-content {
        color: #333;
        background: white;
        border-radius: 14px;
        padding: 1rem 1.1rem;
        border: 1px solid #f1e5d8;
        white-space: pre-wrap;
    }

    .message-empty {
        background: #fff7ed;
        border-left: 6px solid #f97316;
        padding: 1.4rem;
        border-radius: 14px;
    }

    .message-reply {
        margin-top: 1rem;
        background: #fff;
        border-radius: 14px;
        padding: 1rem 1.1rem;
        border: 1px solid #e5e7eb;
    }

    .btn-reply {
        display: inline-block;
        margin-top: 1rem;
        background: #111827;
        color: #fff;
        text-decoration: none;
        padding: 0.7rem 1rem;
        border-radius: 10px;
        font-weight: 600;
    }
</style>

<div class="owner-inbox-page">
    <div class="container">
        <div class="owner-inbox-wrapper">
            <h1 class="owner-inbox-title">Owner Inbox</h1>

            <% if (messages.length > 0) { %>
                <div class="row gy-4">
                    <% messages.forEach((message) => { %>
                        <div class="col-lg-6">
                            <div class="card message-card">
                                <div class="message-card-body">
                                    <div class="message-subject">
                                        <%= message.listing?.title || "Listing unavailable" %>
                                    </div>
                                    <div class="message-meta">
                                        <div><strong>From:</strong> <%= message.name %></div>
                                        <div><strong>Email:</strong> <a href="mailto:<%= message.email %>"><%= message.email %></a></div>
                                        <div><strong>User:</strong> <%= message.sender?.username || "Guest" %></div>
                                        <div><strong>Received:</strong> <%= new Date(message.createdAt).toLocaleString("en-IN") %></div>
                                    </div>
                                    <div class="message-content"><%= message.message %></div>
                                    <% if (message.replyMessage) { %>
                                        <div class="message-reply">
                                            <strong>Reply sent on <%= new Date(message.repliedAt).toLocaleString("en-IN") %>:</strong>
                                            <div class="mt-2"><%= message.replyMessage %></div>
                                        </div>
                                    <% } %>
                                    <a href="/owner/messages/<%= message._id %>/reply" class="btn-reply">
                                        <%= message.replyMessage ? "Edit Reply" : "Reply to Guest" %>
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="message-empty">
                    <p class="mb-0">No owner messages yet. When guests use the contact form, their messages will appear here.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>
