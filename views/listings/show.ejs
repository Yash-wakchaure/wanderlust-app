<% layout("/layouts/boilerplate") %>  
<div class="row mt-3">
<div class="col-8 offset-3">

     <h3><%=listing.title %></h3>
 
     </div></div>
     <div class="card col-6 offset-3 show-card listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing image">
     <div class="card-body">
      <p class="card-text">Owned By <i><%= listing.owner.username %></i></p>
      <p class="card-text"> <%= listing.description %> </p>
      <p class="card-text">Category:<%= listing.category %> </p>
      <p class="card-text"><%= listing.bedrooms || 1 %> bedrooms · <%= listing.beds || 1 %> beds</p>
      <p class="card-text"> &#8377; <b><%= listing.price?.toLocaleString("en-IN") || "N/A" %>/</b> Day</p>
      <p class="card-text"> <i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>   
      <!-- <p class="card-text"> <%= listing.country %></p> -->
     </div>
     </div>


    <% if(currUser && listing.owner.equals(currUser._id)) { %>
    <div class="btns">
       <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>
       <a href="/listings/<%= listing._id %>/bookings" class="btn btn-info offset-2">View Bookings</a>
       <form method="post" action="/listings/<%= listing._id %>/?_method=Delete">
            <button class="btn btn-dark offset-5">Delete</button>
       </form>
    </div>
    <% } else if(currUser) { %>
       <div class="btns mb-3">
          <a href="/listings/<%= listing._id %>/book" class="btn btn-primary col-3 offset-3">Book Now</a>
          <a href="/listings/<%= listing._id %>/contact" class="btn btn-success col-3 ms-2">Contact Owner</a>
       </div>
    <% } else { %>
       <div class="btns mb-3">
          <p class="text-muted offset-3"><a href="/users/login">Login</a> to book this listing</p>
       </div>
    <% } %>

<!-- Map Section -->
<div class="col-8 offset-3 mb-3 mt-4">
   <div class="map-container">
      <h4 class="map-title">Location on Map</h4>
      <div id="map" class="map-box"></div>
   </div>
</div>

<div class="col-8 offset-3 mb-3">
   <% if(currUser) { %>
   <hr>
   <h4>Leave a Review</h4>
   <form 
        action="/listings/<%= listing.id %>/reviews" 
        method="post"
        novalidate
        class="needs-validation"
        >
         <div class="mb-3 mt-3">
         <label for="rating" class="form-label">Rating</label>
         <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
         </fieldset>
         </div>


         <div class="mb-3 mt-3">
            <label for="comment">Comment</label>
            <textarea
                   name="review[comment]"
                   id="comment" 
                   cols="30" rows="5" 
                   class="form-control" required></textarea>
            <div id="comment" class="invalid-feedback">
                    Please add some comment for review
            </div>
         </div>
         <button class="btn btn-outline-dark">Submit</button>
   </form>
   <% } %> 
   <hr>

      <% if(listing.reviews.length > 0) { %>
      <div class="row">
         <p><b>All Reviews</b></p>
      <% for(review of listing.reviews) { %>
          <div class="card mb-3 ms-3 col-5">
            <div class="card-body">
               <h5 class="card-title">@<%= review.author.username %></h5>
               <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
               <p class="card-text"><%= review.comment %></p>
            </div>
            <form class="mb-3" method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=Delete">
               <button class="btn btn-sm btn-dark mt-3">Delete</button>
            </form>
          </div>
         
      <% } %>
      </div>
      <% } %>
</div>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
   .map-container {
      background: white;
      padding: 2rem;
      border-radius: 15px;
      box-shadow: 0 10px 35px rgba(0,0,0,0.08);
   }

   .map-title {
      color: #2c3e50;
      font-weight: 700;
      margin-bottom: 1.5rem;
      font-size: 1.3rem;
   }

   .map-box {
      height: 450px;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 8px 25px rgba(102, 126, 234, 0.15);
   }

   .map-box .leaflet-container {
      border-radius: 12px;
   }

   .leaflet-popup-content-wrapper {
      border-radius: 12px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
   }

   .leaflet-popup-content {
      color: white;
      font-weight: 600;
   }

   .location-marker {
      background: none;
      border: none;
      width: auto;
      height: auto;
   }

   /* Custom SVG marker styling */
   .marker-pin {
      width: 50px;
      height: 60px;
      background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
      border-radius: 50% 50% 50% 0;
      transform: rotate(-45deg);
      box-shadow: 0 6px 20px rgba(255, 107, 107, 0.4);
      border: 3px solid white;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
   }

   .marker-pin::after {
      content: '🏠';
      transform: rotate(45deg);
      font-size: 1.5rem;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
   }

</style>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
   document.addEventListener('DOMContentLoaded', function() {
      // Map initialization
      const listingLocation = "<%= listing.location %>";
      const listingTitle = "<%= listing.title %>";
      
      // Initialize map
      const map = L.map('map').setView([20.5937, 78.9629], 4); // Default to India center, zoom 4

      // Add OpenStreetMap tiles
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
         attribution: '© OpenStreetMap contributors',
         maxZoom: 19,
         minZoom: 2
      }).addTo(map);

      // Geocode location and add marker
      async function findLocationAndMarkOnMap() {
         try {
            // Using Nominatim (OpenStreetMap's geocoding service - FREE)
            const response = await fetch(
               `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(listingLocation)}`
            );
            const data = await response.json();
            
            if (data.length > 0) {
               const {lat, lon, display_name} = data[0];
               
               // Set map view to location
               map.setView([lat, lon], 15);
               
               // Create custom marker div
               const markerDiv = document.createElement('div');
               markerDiv.className = 'marker-pin';
               
               // Add marker with custom icon
               const customIcon = L.divIcon({
                  html: markerDiv.outerHTML,
                  iconSize: [50, 60],
                  iconAnchor: [25, 60],
                  popupAnchor: [0, -60],
                  className: 'location-marker'
               });
               
               L.marker([lat, lon], {icon: customIcon})
                  .bindPopup(`<strong>${listingTitle}</strong><br>${display_name}`)
                  .addTo(map)
                  .openPopup();
               
            } else {
               // If location not found, show default
               console.log('Location not found');
               const markerDiv = document.createElement('div');
               markerDiv.className = 'marker-pin';
               
               const customIcon = L.divIcon({
                  html: markerDiv.outerHTML,
                  iconSize: [50, 60],
                  iconAnchor: [25, 60],
                  popupAnchor: [0, -60],
                  className: 'location-marker'
               });
               
               L.marker([20.5937, 78.9629], {icon: customIcon})
                  .bindPopup(`<strong>${listingTitle}</strong><br>${listingLocation}`)
                  .addTo(map);
            }
         } catch (error) {
            console.error('Error geocoding location:', error);
            const markerDiv = document.createElement('div');
            markerDiv.className = 'marker-pin';
            
            const customIcon = L.divIcon({
               html: markerDiv.outerHTML,
               iconSize: [50, 60],
               iconAnchor: [25, 60],
               popupAnchor: [0, -60],
               className: 'location-marker'
            });
            
            L.marker([20.5937, 78.9629], {icon: customIcon})
               .bindPopup(`<strong>${listingTitle}</strong><br>${listingLocation}`)
               .addTo(map);
         }
      }
      
      findLocationAndMarkOnMap();
   });
</script>
